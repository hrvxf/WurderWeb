rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function accountAllowedKeys() {
      return [
        "uid",
        "firstName",
        "lastName",
        "secondName",
        "name",
        "username",
        "usernameLower",
        "wurderId",
        "wurderIdLower",
        "avatar",
        "avatarUrl",
        "photoURL",
        "createdAt",
        "updatedAt"
      ];
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && request.resource.data.uid == request.auth.uid;
      allow update: if isOwner(uid) && request.resource.data.uid == request.auth.uid;
      allow delete: if false;

      match /games/{gameId} {
        allow read, write: if isOwner(uid);
      }
    }


    match /accounts/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly(accountAllowedKeys());
      allow update: if isOwner(uid)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly(accountAllowedKeys())
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(accountAllowedKeys())
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if false;
    }

    match /profiles/{uid} {
      allow read: if isOwner(uid);
      allow create, update, delete: if false;
    }

    match /usernames/{usernameLower} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.usernameLower == usernameLower;
      allow update: if signedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.usernameLower == resource.data.usernameLower
        && request.resource.data.usernameLower == usernameLower
        && request.resource.data.username == resource.data.username;
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
